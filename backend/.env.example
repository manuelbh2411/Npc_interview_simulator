OPENAI_API_KEY=tu_clave_aqui
OPENAI_EVALUATION_MODEL=gpt-4.1-mini
ELEVENLABS_API_KEY=tu_clave_elevenlabs_aqui
ELEVENLABS_AGENT_ID=tu_agent_id_aqui

# Base de datos: SQLite local por defecto. Para PostgreSQL:
# DATABASE_URL=postgresql+psycopg://usuario:password@localhost:5432/tfg_interviews
DATABASE_URL=sqlite:///app/data/tfg_interviews.db

# Seguridad JWT: cambia esta clave en tu .env real.
JWT_SECRET_KEY=cambia_esta_clave_larga_y_aleatoria
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Origenes permitidos separados por coma. Anade aqui Unity/frontend si usa otro host.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000
